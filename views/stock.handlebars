<div class="container">
  <form action="/api/items" method="post" enctype="multipart/form-data">
    <div class="mb-3">
      <label for="code" class="form-label">Codigo</label>
      <input
        type="text"
        name="code"
        class="form-control"
        id="code"
        placeholder=""
        required
      />
    </div>
    <div class="mb-3">
      <label for="title" class="form-label">Nombre</label>
      <input
        type="text"
        name="title"
        class="form-control"
        id="title"
        placeholder=""
        required
      />
    </div>
    <div class="mb-3">
      <label for="description" class="form-label">Descripcion</label>
      <input
        type="text"
        name="description"
        class="form-control"
        id="description"
        placeholder=""
        required
      />
    </div>
    <div class="mb-3">
      <label for="category" class="form-label">Categoria</label>
      <select name="category" id="category">
        <option value="Materiales">Materiales</option>
        <option value="Electricidad">Electricidad</option>
        <option value="Sanitario">Sanitario</option>
        <option value="Seguridad">Seguridad</option>
      </select>
    </div>
    <div class="mb-3">
      <label for="stock" class="form-label">Stock</label>
      <input
        type="number"
        name="stock"
        class="form-control"
        id="stock"
        placeholder=""
        required
      />
    </div>
    <label for="image">Comprobante</label>
    <input type="file" name="voucher" id="voucher" />
    <div class="col-auto">
      <button type="submit" class="btn btn-primary mb-3">Cargar</button>
    </div>
  </form>
</div>